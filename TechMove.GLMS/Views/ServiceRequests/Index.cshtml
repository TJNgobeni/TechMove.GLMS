@model IEnumerable<TechMove.GLMS.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Service Requests</h1>
    <a asp-action="Create" class="btn btn-success">+ New Request</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No service requests found.</div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Client</th>
                <th>Contract</th>
                <th>Description</th>
                <th>Cost (USD)</th>
                <th>Cost (ZAR)</th>
                <th>Status</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Contract?.Client?.Name</td>
                    <td>@item.Contract?.ServiceLevel</td>
                    <td>@item.Description</td>
                    <td>$@item.Cost.ToString("N2")</td>
                    <td>R @item.CostZAR.ToString("N2")</td>
                    <td><span class="badge bg-secondary">@item.Status</span></td>
                    <td>@item.CreatedAt.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}