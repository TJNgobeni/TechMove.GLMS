@model TechMove.GLMS.Models.Contract
@using TechMove.GLMS.Models.Enums

@{
    ViewData["Title"] = "Contract Details";
}

<h1>Contract Details</h1>
<hr />

<dl class="row">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Client?.Name</dd>

    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

    <dt class="col-sm-3">Days Remaining</dt>
    <dd class="col-sm-9">@Model.DaysRemaining</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @{
            var badgeClass = Model.Status switch
            {
                ContractStatus.Active => "bg-success",
                ContractStatus.Expired => "bg-danger",
                ContractStatus.OnHold => "bg-warning text-dark",
                _ => "bg-secondary"
            };
        }
        <span class="badge @badgeClass">@Model.Status</span>
    </dd>

    <dt class="col-sm-3">Service Level</dt>
    <dd class="col-sm-9">@Model.ServiceLevel</dd>

    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
    {
        <dt class="col-sm-3">Signed Agreement</dt>
        <dd class="col-sm-9">
            <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-sm btn-secondary">Download PDF</a>
        </dd>
    }
</dl>

@if (Model.ServiceRequests?.Any() == true)
{
    <h4 class="mt-4">Service Requests</h4>
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Description</th>
                <th>Cost (USD)</th>
                <th>Cost (ZAR)</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var req in Model.ServiceRequests)
            {
                <tr>
                    <td>@req.Description</td>
                    <td>$@req.Cost.ToString("N2")</td>
                    <td>R @req.CostZAR.ToString("N2")</td>
                    <td><span class="badge bg-secondary">@req.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>