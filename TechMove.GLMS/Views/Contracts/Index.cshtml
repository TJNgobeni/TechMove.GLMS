@model IEnumerable<TechMove.GLMS.Models.Contract>
@using TechMove.GLMS.Models.Enums

@{
    ViewData["Title"] = "Contracts";
    var currentStart = Context.Request.Query["startDate"].ToString();
    var currentEnd = Context.Request.Query["endDate"].ToString();
    var currentStatus = Context.Request.Query["status"].ToString();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Contracts</h1>
</div>

<form asp-action="Index" method="get" class="card card-body bg-light mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Start Date</label>
            <input type="date" name="startDate" class="form-control" value="@currentStart" />
        </div>
        <div class="col-md-3">
            <label class="form-label">End Date</label>
            <input type="date" name="endDate" class="form-control" value="@currentEnd" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
                <option value="">-- All --</option>
                @foreach (ContractStatus s in Enum.GetValues(typeof(ContractStatus)))
                {
                    <option value="@s" selected="@(currentStatus == s.ToString() ? "selected" : null)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            <a asp-action="Create" class="btn btn-success">+ New</a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No contracts found.
        @if (!string.IsNullOrEmpty(currentStart) || !string.IsNullOrEmpty(currentEnd) || !string.IsNullOrEmpty(currentStatus))
        {
            <span> — <a asp-action="Index">Clear filters</a> to see all contracts.</span>
        }
    </div>
}
else
{
    <p class="text-muted">Showing @Model.Count() contract(s).</p>
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Client</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Days Remaining</th>
                <th>Status</th>
                <th>Service Level</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Client?.Name</td>
                    <td>@item.StartDate.ToShortDateString()</td>
                    <td>@item.EndDate.ToShortDateString()</td>
                    <td>
                        @if (item.IsExpiredByDate)
                        {
                            <span class="text-danger">Expired</span>
                        }
                        else
                        {
                            <span>@item.DaysRemaining days</span>
                        }
                    </td>
                    <td>
                        @{
                            var badgeClass = item.Status switch
                            {
                                ContractStatus.Active => "bg-success",
                                ContractStatus.Expired => "bg-danger",
                                ContractStatus.OnHold => "bg-warning text-dark",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@item.Status</span>
                    </td>
                    <td>@item.ServiceLevel</td>
                    <td class="d-flex gap-1">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                        {
                            <a asp-action="Download" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Download</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
